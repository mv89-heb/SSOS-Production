# Neon PostgreSQL connection string. Either postgres:// or postgresql:// works;
# the app rewrites postgres:// to postgresql:// automatically. Include sslmode=require.
DATABASE_URL=postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/ssos?sslmode=require

# Flask
FLASK_ENV=production
FLASK_APP=wsgi.py
SECRET_KEY=change-this-to-a-long-random-value

# Security
SESSION_COOKIE_SECURE=True
WTF_CSRF_ENABLED=True

# CORS — comma-separated list of origins allowed to call this API with
# credentials (the Next.js frontend's deployed URL). Must NOT be "*" since
# credentialed requests require an explicit origin.
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.example.com

# Uploads
MAX_UPLOAD_SIZE=5242880

# Rate limiting
RATELIMIT_LOGIN=10 per minute
RATELIMIT_STORAGE_URI=memory://
